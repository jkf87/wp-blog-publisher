# ============================================
# WP Blog Publisher 환경 설정
# ============================================
# 이 파일을 .env로 복사하여 사용하세요:
#   cp .env.example .env
#
# .env 파일은 절대 Git에 커밋하지 마세요.
# ============================================

# 워드프레스 사이트 URL (필수)
WP_URL=https://내이름.up.railway.app

# 워드프레스 계정명 (필수)
WP_USER=your-wp-username

# Application Password (필수 — 로그인 비밀번호가 아님!)
# 발급: wp-admin → 사용자 → 프로필 → Application Passwords
# 형식: xxxx xxxx xxxx xxxx xxxx xxxx
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# 게시 상태: publish 또는 draft (선택, 기본: publish)
WP_POST_STATUS=publish
